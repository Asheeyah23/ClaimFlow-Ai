# Server
PORT=5000
CORS_ORIGIN=*

# Auth
JWT_SECRET=change-me-to-a-long-random-string
JWT_EXPIRES=7d

# Database (SQLite file path — defaults to ./claimflow.db)
# DB_PATH=./claimflow.db

# AI fraud engine (optional).
# Without a key, ClaimFlow uses its built-in heuristic engine.
# With a key, the Fraud Agent reasons with Claude.
# ANTHROPIC_API_KEY=sk-ant-...
# CLAUDE_MODEL=claude-haiku-4-5-20251001

# UiPath Orchestrator / Maestro (optional).
# When all of the following are set, submitting a claim starts an Orchestrator job and
# passes the claim payload as InputArguments. Leave unset to skip orchestration entirely.
# Find ACCOUNT/TENANT in your Orchestrator URL: https://cloud.uipath.com/{ACCOUNT}/{TENANT}/...
# (For the hackathon staging tenant set UIPATH_BASE_URL=https://staging.uipath.com)
# UIPATH_BASE_URL=https://cloud.uipath.com
# UIPATH_ACCOUNT=hackathon26_1006
# UIPATH_TENANT=DefaultTenant
# UIPATH_CLIENT_ID=your-external-app-client-id
# UIPATH_CLIENT_SECRET=your-external-app-client-secret
# UIPATH_FOLDER_ID=your-organization-unit-folder-id
# UIPATH_RELEASE_NAME=YourProcessOrReleaseName
# UIPATH_SCOPE=OR.Jobs
# UIPATH_STRATEGY=ModernJobsCount
